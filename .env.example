# X/Twitter API (get from developer.x.com)
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=
X_LIST_ID=

# Claude Server (your server that proxies Claude API calls)
CLAUDE_SERVER_URL=
CLAUDE_SERVER_API_TOKEN=

# Auth gate for the deployed app (REQUIRED — min 16 chars).
# Generate with: openssl rand -base64 32
# Use any username + this value as the password when the browser prompts.
WEBAPP_SECRET=

# Chrome extension ID (from chrome://extensions after loading the unpacked extension)
NEXT_PUBLIC_EXTENSION_ID=
